# Anthropic API key — used by RLM sub_lm() calls and the LLM research helper.
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: higher rate limits for free APIs you actually use.
# All have generous free tiers; only fill these in if you've signed up.
COINGECKO_API_KEY=
# Defaults to demo tier (BASE + x-cg-demo-api-key). Set to "pro" only if you
# hold a paid CoinGecko Pro key (which uses pro-api.coingecko.com).
COINGECKO_API_TIER=
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# FRED (Federal Reserve Economic Data) — Fed funds rate + M2 YoY for macro.
# Free signup: https://fredaccount.stlouisfed.org/apikey
FRED_API_KEY=

# Dune Analytics — chain DAU + CEX flows for onchain agent. Free tier 2,500
# credits/month at https://dune.com → Settings → API. Without this, onchain
# agent emits data_quality=UNAVAILABLE for chain-class tokens (no fabrication).
DUNE_API_KEY=

# Default models — override per-call if you want.
RLM_ROOT_MODEL=claude-opus-4-6
RLM_SUB_MODEL=claude-sonnet-4-6
RESEARCH_MODEL=claude-sonnet-4-6
