# Anthropic API key — used by RLM sub_lm() calls and the LLM research helper.
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: higher rate limits for free APIs you actually use.
# All have generous free tiers; only fill these in if you've signed up.
COINGECKO_API_KEY=
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# Default models — override per-call if you want.
RLM_ROOT_MODEL=claude-opus-4-6
RLM_SUB_MODEL=claude-sonnet-4-6
RESEARCH_MODEL=claude-sonnet-4-6
